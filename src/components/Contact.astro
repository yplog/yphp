---
import Icon from "./icons/Icon.astro";
---

<div class="flex flex-row gap-6">
  <a
    class="hover:opacity-80"
    href="https://fosstodon.org/@yplog"
    target="_blank"
    aria-label="Mastodon profile"
  >
    <Icon name="mastodon" />
  </a>

  <a
    class="hover:opacity-80"
    href="https://github.com/yplog"
    target="_blank"
    aria-label="GitHub profile"
  >
    <Icon name="github" />
  </a>

  <a
    class="hover:opacity-80"
    href="https://codeberg.org/yplog"
    target="_blank"
    aria-label="Codeberg profile"
  >
    <Icon name="codeberg" />
  </a>


  <a
    class="hover:opacity-80"
    href="https://app.ens.domains/yalin.eth"
    target="_blank"
    aria-label="Ethereum ENS profile"
  >
    <Icon name="ethereum" />
  </a>

  <a
    class="hover:opacity-80"
    href="https://www.linkedin.com/in/yalin-pala/"
    target="_blank"
    aria-label="LinkedIn profile"
  >
    <Icon name="linkedin" />
  </a>

  <a
    class="hover:opacity-80"
    href="mailto:yalinpala@pm.me"
    target="_blank"
    aria-label="Send email"
  >
    <Icon name="email" />
  </a>

  <a
    class="hover:opacity-80"
    href="/about#gpg-key"
    title="GNU Privacy Guard"
  >
    <Icon name="gnupg" />
  </a>
</div>
